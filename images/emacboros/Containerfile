FROM quay.io/fedora/fedora@sha256:0ad2ef05326ffb8b2db89c36117fa5c430b61aed3c0432dedeae5bd9759e71af

RUN dnf update -y

RUN dnf install -y \
        emacs \
        bash \
        coreutils \
        findutils \
        git \
        curl \
        bind-utils \
        nmap \
        nmap-ncat \
        openssl \
        python3 \
        python3-pip \
        jq \
        whois \
        traceroute \
        tcpdump \
        ripgrep \
        sed \
        grep \
        gawk \
        tar \
        gzip \
        unzip \
        make \
        gcc \
    && dnf clean all

RUN mkdir -p /root/workspace
RUN mkdir -p /root/i.ar
RUN mkdir -p /root/.emacs.d

# Preflight mount audit script — runs before Emacs to verify container hardening
COPY scripts/preflight.sh /usr/local/bin/preflight.sh
RUN chmod +x /usr/local/bin/preflight.sh

# ---------------------------------------------------------------------------
# Working directory
# ---------------------------------------------------------------------------
WORKDIR /root
USER root

# Preflight audit runs first, then Emacs starts if the audit passes
ENTRYPOINT ["/bin/bash", "-c", "preflight.sh && exec emacs --no-x --load /root/.emacs.d/init.el"]
